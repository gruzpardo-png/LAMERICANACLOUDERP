function toggleMethod() {
  const method = document.getElementById('method')?.value;
  const kilo = document.getElementById('value_kilo_wrap');
  const target = document.getElementById('target_price_wrap');
  if (!kilo || !target) return;
  if (method === 'objetivo') {
    kilo.classList.add('hidden');
    target.classList.remove('hidden');
  } else {
    kilo.classList.remove('hidden');
    target.classList.add('hidden');
  }
}
function toggleWeight() {
  const source = document.getElementById('weight_source')?.value;
  const manual = document.getElementById('manual_weight_wrap');
  if (!manual) return;
  if (source === 'manual') manual.classList.remove('hidden');
  else manual.classList.add('hidden');
}
document.addEventListener('DOMContentLoaded', () => {
  toggleMethod();
  toggleWeight();
});
